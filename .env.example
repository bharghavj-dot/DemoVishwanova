# TriLens Backend Environment Variables (Render Deploy)
# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────
# For local: PostgreSQL connection string
# For Render: Use DATABASE_URL from Render dashboard
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/trilens

# ── Gemini API (FREE) ──────────────────────────────
# Get from: https://aistudio.google.com/apikey
# Free tier: 60 requests/minute (plenty for testing)
GEMINI_API_KEY=your-gemini-api-key-here

# ── Twilio Voice (PAY-AS-YOU-GO) ───────────────────
# Get from: https://www.twilio.com/console
# Cost: ~$0.0075/min for calls (unavoidable infrastructure cost)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WEBHOOK_BASE_URL=https://your-backend.onrender.com

# ── CORS (Allow frontend access) ────────────────
CORS_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com

# ── Voice Mode (websocket | simple) ──────────────────────────
# websocket: Full AI conversation (requires pyttsx3)
# simple: Basic greeting only (uses Twilio TTS, most reliable)
VOICE_MODE=websocket

# ── Twilio Voice Integration ─────────────────────────────────
# Sign up at https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# For local dev: run `ngrok http 8000` and paste the HTTPS URL here
# For production: use your Render deploy URL (e.g. https://trilens-api.onrender.com)
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-or-production-url.com