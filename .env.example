# Trilens — Environment Configuration
# Copy to .env and fill in your values

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production

# ── LLM Provider (gemini | openai | offline) ─────────────────────
LLM_PROVIDER=offline

# ── Google Gemini API Key (if using gemini provider) ─────────────
GEMINI_API_KEY=


# ── CORS Origins (comma-separated) ───────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/trilens

# ── Twilio Voice Integration ─────────────────────────────────
# Sign up at https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# For local dev: run `ngrok http 8000` and paste the HTTPS URL here
# For production: use your Render deploy URL (e.g. https://trilens-api.onrender.com)
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-or-production-url.com